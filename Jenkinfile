pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                credentialsId: 'github-token',
                url: 'https://github.com/Sirigidibalaji/projectOne.git'
            }
        }

        stage('Build') {
            steps {
                echo 'Website Build Successful'
            }
        }

        stage('Test') {
            steps {
                echo 'Testing Completed'
            }
        }

        stage('Run Website') {
            steps {
                bat '''
                cd %WORKSPACE%
                start "" index.html
                '''
            }
        }
    }

    post {
        success {
            echo 'Website Opened Successfully'
        }
        failure {
            echo 'Pipeline Failed'
        }
    }
}
