pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    credentialsId: 'github-token',
                    url: 'https://github.com/Sirigidibalaji/projectOne.git'
            }
        }

        stage('Build') {
            steps {
                echo 'Website Build Successful'
            }
        }

        stage('Test') {
            steps {
                echo 'Testing Completed'
            }
        }

        stage('Check Files') {
            steps {
                bat '''
                echo Workspace Location:
                echo %WORKSPACE%
                echo.
                echo Files in Workspace:
                dir
                '''
            }
        }

        stage('Run Website') {
            steps {
                bat '''
                start "" "%WORKSPACE%\\index.html"
                '''
            }
        }
    }

    post {
        success {
            echo 'Pipeline Completed Successfully'
        }

        failure {
            echo 'Pipeline Failed'
        }
    }
}
